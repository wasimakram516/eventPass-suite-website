NEXT_PUBLIC_EVENTPASS_URL=https://eventpass.whitewall.solutions/
NEXT_PUBLIC_NODE_ENV=development

# SMTP configuration for contact form (server-side only)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
CONTACT_TO_EMAIL=connect@whitewall.om
CONTACT_FROM_EMAIL=eventpass-website@whitewall.om

# Contact form email address (used in the contact form)
CONTACT_EMAIL=connect@whitewall.om